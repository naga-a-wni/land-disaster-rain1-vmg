# spool WNI_SRF_ASM_DEWTMP_OWN
[SPOOL_RD_10V_OWN_DEWTMP]
Command=/usr/amoeba/tools/SPOOL_DEW_POINT/scripts/spool_dew_point.rb /usr/amoeba/tools/SPOOL_DEW_POINT/config/config.yml %input
LogFile=/usr/amoeba/log/SPOOL_DEW_POINT/spool_asm_dewtmp.log
WaitList=RECV_WNI_SRF_ASM_DEWTMP_OWN


#--------------------------
# FCASJP.xml spool 
#--------------------------
[SPOOL_FCASJP_XML]
Command=/usr/amoeba/tools/LAND_SRF_RD_2020/scripts/ruheadercut2.rb %input /usr/amoeba/spool/workspace/SPOOL_JBHONSI_MANUALENTERED/FCASJP.xml
LogFile=/usr/amoeba/log/SPOOL_JBHONSI_MANUALENTERED/spool_fcasjp_xml.log
WaitList=RECV_FCASJP_XML
#
[SPOOL_FCASJP_ASM_LCLID]
Command=/usr/amoeba/tools/SPOOL_JBHONSI_MANUALENTERED/scripts/spool_asm_lclid.rb /usr/amoeba/spool/workspace/SPOOL_JBHONSI_MANUALENTERED/FCASJP.xml /usr/amoeba/tools/SPOOL_JBHONSI_MANUALENTERED/config/config.yml
LogFile=/usr/amoeba/log/SPOOL_JBHONSI_MANUALENTERED/spool_fcasjp_xml.log
WaitList=SPOOL_FCASJP_XML

#--------------------------
# update winter obs points 
#--------------------------
[UPDATE_WINTER_OBS_POINTS_TABLE]
Command=/usr/amoeba/tools/SPOOL_JBHONSI_MANUALENTERED/scripts/rd_winter_obs_points.rb /usr/amoeba/tools/SPOOL_JBHONSI_MANUALENTERED/config/config.yml
LogFile=/usr/amoeba/log/SPOOL_JBHONSI_MANUALENTERED/rd_winter_obs_points.log
WaitList=PARSE_RD_TABLE_10V_WINTER_XML
#
[UPDATE_WINTER_OBS_POINTS_FCASJP]
Command=/usr/amoeba/tools/SPOOL_JBHONSI_MANUALENTERED/scripts/rd_winter_obs_points.rb /usr/amoeba/tools/SPOOL_JBHONSI_MANUALENTERED/config/config.yml
LogFile=/usr/amoeba/log/SPOOL_JBHONSI_MANUALENTERED/rd_winter_obs_points.log
WaitList=SPOOL_FCASJP_ASM_LCLID

#--------------------------------------
# JB本四 観測情報入力 寒候期区間ID付き 
#--------------------------------------
[SPOOL_NEXCO_OBS_HONSI_ManualEntered_WNTR_zoneID]
Command=/usr/amoeba/tools/SPOOL_JBHONSI_MANUALENTERED/scripts/spool_jbhonsi_manualentered.rb /usr/amoeba/tools/SPOOL_JBHONSI_MANUALENTERED/config/config.yml %input
LogFile=/usr/amoeba/log/SPOOL_JBHONSI_MANUALENTERED/spool_jbhonsi_manualentered.log
WaitList=RECV_NEXCO_OBS_HONSI_ManualEntered_WNTR_zoneID
